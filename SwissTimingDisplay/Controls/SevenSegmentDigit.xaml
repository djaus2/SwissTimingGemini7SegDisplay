<UserControl x:Class="SwissTimingDisplay.Controls.SevenSegmentDigit"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             d:DesignHeight="120" d:DesignWidth="70">
    <UserControl.Resources>
        <SolidColorBrush x:Key="SegmentOnBrush" Color="#FFF6E600" />
        <SolidColorBrush x:Key="SegmentOffBrush" Color="#FF1A1A00" />
    </UserControl.Resources>
    <Viewbox Stretch="Uniform">
        <Grid Width="70" Height="120" Background="Black">
            <Rectangle x:Name="SegA" Height="10" RadiusX="2" RadiusY="2" Margin="10,8,10,0" VerticalAlignment="Top" Fill="{StaticResource SegmentOffBrush}" />
            <Rectangle x:Name="SegD" Height="10" RadiusX="2" RadiusY="2" Margin="10,0,10,8" VerticalAlignment="Bottom" Fill="{StaticResource SegmentOffBrush}" />
            <Rectangle x:Name="SegG" Height="10" RadiusX="2" RadiusY="2" Margin="10,0,10,0" VerticalAlignment="Center" Fill="{StaticResource SegmentOffBrush}" />

            <Rectangle x:Name="SegB" Width="10" RadiusX="2" RadiusY="2" Margin="0,14,8,0" HorizontalAlignment="Right" VerticalAlignment="Top" Height="44" Fill="{StaticResource SegmentOffBrush}" />
            <Rectangle x:Name="SegC" Width="10" RadiusX="2" RadiusY="2" Margin="0,0,8,14" HorizontalAlignment="Right" VerticalAlignment="Bottom" Height="44" Fill="{StaticResource SegmentOffBrush}" />

            <Rectangle x:Name="SegF" Width="10" RadiusX="2" RadiusY="2" Margin="8,14,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Height="44" Fill="{StaticResource SegmentOffBrush}" />
            <Rectangle x:Name="SegE" Width="10" RadiusX="2" RadiusY="2" Margin="8,0,0,14" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="44" Fill="{StaticResource SegmentOffBrush}" />
        </Grid>
    </Viewbox>
</UserControl>

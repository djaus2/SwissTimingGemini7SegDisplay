<UserControl x:Class="SwissTimingDisplay.Controls.SixDigitSevenSegmentDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:controls="clr-namespace:SwissTimingDisplay.Controls"
             xmlns:converters="clr-namespace:SwissTimingDisplay.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="500">
    <UserControl.Resources>
        <converters:TimeInputDigitConverter x:Key="TimeInputDigitConverter" />
        <converters:TimeInputSeparatorVisibilityConverter x:Key="TimeInputSeparatorVisibilityConverter" />
    </UserControl.Resources>

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
        <controls:SevenSegmentDigit Digit="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputDigitConverter}, ConverterParameter=0}" />

        <Grid Width="18" Height="120" Margin="10,0,10,0">
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Top" Margin="0,34,0,0" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=colon:1}" />
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Top" Margin="0,62,0,0" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=colon:1}" />
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Bottom" Margin="0,0,0,20" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=dot:1}" />
        </Grid>

        <controls:SevenSegmentDigit Margin="6,0,0,0" Digit="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputDigitConverter}, ConverterParameter=1}" />

        <Grid Width="18" Height="120" Margin="10,0,10,0">
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Top" Margin="0,34,0,0" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=colon:2}" />
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Top" Margin="0,62,0,0" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=colon:2}" />
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Bottom" Margin="0,0,0,20" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=dot:2}" />
        </Grid>

        <controls:SevenSegmentDigit Digit="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputDigitConverter}, ConverterParameter=2}" />

        <Grid Width="18" Height="120" Margin="10,0,10,0">
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Top" Margin="0,34,0,0" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=colon:3}" />
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Top" Margin="0,62,0,0" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=colon:3}" />
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Bottom" Margin="0,0,0,20" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=dot:3}" />
        </Grid>

        <controls:SevenSegmentDigit Margin="6,0,0,0" Digit="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputDigitConverter}, ConverterParameter=3}" />

        <Grid Width="18" Height="120" Margin="10,0,10,0">
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Top" Margin="0,34,0,0" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=colon:4}" />
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Top" Margin="0,62,0,0" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=colon:4}" />
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Bottom" Margin="0,0,0,20" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=dot:4}" />
        </Grid>

        <controls:SevenSegmentDigit Digit="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputDigitConverter}, ConverterParameter=4}" />

        <Grid Width="18" Height="120" Margin="10,0,10,0">
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Top" Margin="0,34,0,0" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=colon:5}" />
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Top" Margin="0,62,0,0" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=colon:5}" />
            <Ellipse Width="10" Height="10" Fill="#FFF6E600" VerticalAlignment="Bottom" Margin="0,0,0,20" HorizontalAlignment="Center" Visibility="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputSeparatorVisibilityConverter}, ConverterParameter=dot:5}" />
        </Grid>

        <controls:SevenSegmentDigit Margin="6,0,0,0" Digit="{Binding TimeInput, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource TimeInputDigitConverter}, ConverterParameter=5}" />
    </StackPanel>
</UserControl>

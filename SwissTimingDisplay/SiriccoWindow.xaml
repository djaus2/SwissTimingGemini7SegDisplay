<Window x:Class="SwissTimingDisplay.SiriccoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SwissTimingDisplay"
        xmlns:controls="clr-namespace:SwissTimingDisplay.Controls"
        xmlns:converters="clr-namespace:SwissTimingDisplay.Converters"
        xmlns:System="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="SIRICCO" Height="466" Width="775" Closing="Window_Closing"
        Background="#E8F5E9">
    <Window.Resources>
        <ObjectDataProvider x:Key="SiriccoMessageModesEnum" MethodName="GetValues" ObjectType="{x:Type System:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="local:SiriccoMessageModes" />
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <x:Array x:Key="SiriccoMessageModesFiltered" Type="local:SiriccoMessageModes">
            <local:SiriccoMessageModes>Gill_PolarContinuous</local:SiriccoMessageModes>
            <local:SiriccoMessageModes>Gill_UVContinuous</local:SiriccoMessageModes>
            <local:SiriccoMessageModes>NMEANMEA</local:SiriccoMessageModes>
            <local:SiriccoMessageModes>NMEAGill</local:SiriccoMessageModes>
            <local:SiriccoMessageModes>Gill_Tunnel</local:SiriccoMessageModes>
            <local:SiriccoMessageModes>WindGauge_ReadFrequency</local:SiriccoMessageModes>
        </x:Array>

        <converters:TimeInputDigitConverter x:Key="TimeInputDigitConverter" />

        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter" />

        <converters:TimeInputSeparatorVisibilityConverter x:Key="TimeInputSeparatorVisibilityConverter" />

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <converters:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />

        <converters:UnderscoreToSpaceConverter x:Key="UnderscoreToSpaceConverter" />
        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="DarkGreen" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinWidth" Value="150" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style x:Key="RadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="Green" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>
    <Grid x:Name="rootGrid" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
            <Image Source="pack://application:,,,/docs/SwissTiming.png" Height="40" Stretch="Uniform" VerticalAlignment="Center" />
            <TextBlock FontSize="21" FontWeight="ExtraBlack"  FontStyle="Italic" Foreground="Black" VerticalAlignment="Center" Margin="8,0,0,0" ><Run Language="en-au" Text="SIRICCO"/></TextBlock>
        </StackPanel>

        <GroupBox Grid.Row="2" Margin="0,12,0,0" Background="Beige">
            <GroupBox.Header>
                <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Blue" Text="Settings" />
            </GroupBox.Header>
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <CheckBox Grid.Column="0" VerticalAlignment="Center" IsChecked="{Binding OnlyProlific}">
                    <CheckBox.Content>
                        <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Purple" Text="Only Prolific (PL*)" />
                    </CheckBox.Content>
                </CheckBox>
                <Button Grid.Column="1" Margin="12,0,0,0" Padding="10,4" Command="{Binding RefreshPortsCommand}" Style="{StaticResource SnazzyButtonStyle}">
                    <Button.Content>
                        <TextBlock FontWeight="Bold" FontStyle="Italic" Text="Refresh Ports" />
                    </Button.Content>
                </Button>
                <CheckBox Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" IsChecked="{Binding ShowSimulator}" ToolTip="Requires Loopback Cable">
                    <CheckBox.Content>
                        <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Purple" Text="Use Siricco Simulator" />
                    </CheckBox.Content>
                </CheckBox>
                <TextBlock Grid.Column="3" Margin="12,0,4,0" VerticalAlignment="Center" FontWeight="Bold" FontStyle="Italic" Foreground="Purple" Text="Message Mode:" />
                <ComboBox Grid.Column="4" Margin="4,0,0,0" VerticalAlignment="Center" Style="{StaticResource ComboBoxStyle}" ItemsSource="{Binding Source={StaticResource SiriccoMessageModesFiltered}}" SelectedItem="{Binding SiriccoMessageMode}" SelectionChanged="SiriccoMessageMode_SelectionChanged" />
                <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnBackToMain" Margin="0,0,0,0" Padding="10,4" Content="Back to Main" Click="BackToMainButton_Click" Style="{StaticResource SnazzyButtonStylePurple}" />
                    <Button x:Name="btnExit" Margin="12,0,0,0" Padding="10,4" Content="Exit" Click="ExitButton_Click" Style="{StaticResource SnazzyButtonStyleRed}" />
                </StackPanel>
                <CheckBox x:Name="cbUseWallClock" Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Center" IsChecked="{Binding UseWallClockTimeOfDay}" Checked="UseWallClock_Checked" Unchecked="UseWallClock_Unchecked" Visibility="Collapsed">
                    <CheckBox.Content>
                        <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Purple" Text="Use wall clock" />
                    </CheckBox.Content>
                </CheckBox>
                <CheckBox x:Name="cbAnchorDisplay" Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Center" IsChecked="{Binding AnchorDisplay}" Visibility="Collapsed">
                    <CheckBox.Content>
                        <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Purple" Text="Anchor Display" />
                    </CheckBox.Content>
                </CheckBox>
                <CheckBox Grid.Column="4" Margin="12,0,0,0" VerticalAlignment="Center" IsChecked="{Binding ShowSimulatorPunctuation}" Visibility="Collapsed">
                    <CheckBox.Content>
                        <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Purple" Text="Show Punctuation in Simulated Display" />
                    </CheckBox.Content>
                </CheckBox>
                <CheckBox Grid.Column="5" Margin="12,0,0,0" VerticalAlignment="Center" IsChecked="{Binding IsDisplayModeHHMMSS}" IsEnabled="{Binding Cosmetic}" Visibility="Collapsed">
                    <CheckBox.Content>
                        <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Purple" Text="{Binding DisplayModeLabel}" />
                    </CheckBox.Content>
                </CheckBox>
                <CheckBox x:Name="cbNumDigits" Grid.Column="6" Margin="12,0,0,0" VerticalAlignment="Center" IsChecked="{Binding IsNumDigits9}" Visibility="Collapsed">
                    <CheckBox.Content>
                        <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Purple" Text="{Binding NumDigitsLabel}" />
                    </CheckBox.Content>
                </CheckBox>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="3" Margin="0,12,0,0" Background="Beige">
            <GroupBox.Header>
                <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Blue" Text="Serial" />
            </GroupBox.Header>
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Send Port" FontWeight="Bold" FontStyle="Italic" Foreground="Purple" />
                <ComboBox Grid.Row="0" Grid.Column="1"
                          Margin="12,0,0,0"
                          ItemsSource="{Binding SendPortsView}"
                          SelectedValuePath="PortName"
                          SelectedValue="{Binding SelectedSendPortName}"
                          DisplayMemberPath="DisplayName"
                          Style="{StaticResource ComboBoxStyle}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,8,0,0" VerticalAlignment="Center" Text="Simulator Port" FontWeight="Bold" FontStyle="Italic" Foreground="Purple">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowSimulator}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <ComboBox Grid.Row="1" Grid.Column="1"
                          Margin="12,8,0,0"
                          ItemsSource="{Binding ReceivePortsView}"
                          SelectedValuePath="PortName"
                          SelectedValue="{Binding SelectedReceivePortName}"
                          DisplayMemberPath="DisplayName">
                    <ComboBox.Style>
                        <Style TargetType="ComboBox" BasedOn="{StaticResource ComboBoxStyle}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowSimulator}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.Style>
                </ComboBox>

                <Button Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Margin="12,0,0,0" Padding="10,4" Command="{Binding SendConnectToggleCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SnazzyButtonStyle}">
                            <Setter Property="Content" Value="Connect" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Content" Value="Disconnect" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Margin="12,8,0,0" Padding="10,4" Command="{Binding ReceiveConnectToggleCommand}" Height="26" VerticalAlignment="Top">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SnazzyButtonStyle}">
                            <Setter Property="Content" Value="Connect" />
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsReceiveConnected}" Value="True">
                                    <Setter Property="Content" Value="Disconnect" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ShowSimulator}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </GroupBox>

        <Grid x:Name="commandsHostGrid" Grid.Row="4" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="commandsColumn" Width="*" />
                <ColumnDefinition x:Name="rightDisplayColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <GroupBox x:Name="commandsGroupBox" Grid.Column="0" Background="Beige">
                <GroupBox.Header>
                    <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Blue" Text="Siricco Commands" />
                </GroupBox.Header>
                <Grid Margin="10" Grid.IsSharedSizeScope="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="622.093" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,0,6" Text="TCP Command" FontWeight="Bold" FontStyle="Italic" Foreground="Purple" />

                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,6">
                        <Button x:Name="btnSiriccoStart" Margin="8,0,0,0" Padding="10,4" Content="      Start      " Click="Siricco_StartButton" Style="{StaticResource SnazzyButtonStyleGreen}" />
                        <Button x:Name="btnSendClear" Margin="12,0,0,0" Padding="10,4" Content="Send Stop and Clear" Click="SendClearButton_Click" Style="{StaticResource SnazzyButtonStyleRed}" />
                        <Button x:Name="btnResendLast" Margin="8,0,0,0" Padding="10,4" Content="Resend Last" Click="ResendLastButton_Click"  Style="{StaticResource SnazzyButtonStylePurple}" />
                        <CheckBox x:Name="cbDisplaySimulatorSpeed" Margin="12,0,0,0" VerticalAlignment="Center" IsChecked="{Binding DisplaySimulatorSpeed}">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowSimulator}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>

                            <CheckBox.Content>
                                <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Purple" Text="Display Simulator Speed" />
                            </CheckBox.Content>
                        </CheckBox>
                        <CheckBox x:Name="cbSimulateSpeed" Margin="12,0,0,0" VerticalAlignment="Center" IsChecked="{Binding SimulatedSiriccoWindGaugeRunning}">

                            <CheckBox.Content>
                                <TextBlock FontWeight="Bold" FontStyle="Italic" Foreground="Purple" Text="Simulate Speed" />
                            </CheckBox.Content>
                        </CheckBox>
                        <TextBlock Text="{Binding _vm.SiriccoIsRunning}"/>
                        <TextBlock Text="{Binding SiriccoIsRunning}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,36" Grid.RowSpan="2">
                        <ComboBox Margin="12,0,0,0"
                                  ItemsSource="{Binding WindGaugeTcpCommands}"
                                  SelectedItem="{Binding SelectedTcpCommand}"
                                  Style="{StaticResource ComboBoxStyle}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource UnderscoreToSpaceConverter}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button x:Name="btnSend" Margin="8,0,0,0" Padding="10,4" Content="← Send selected command" Click="ButtonSend_Click" Style="{StaticResource SnazzyButtonStyle}" />
                    </StackPanel>


                    <Grid Grid.Row="3" Grid.Column="0" Margin="0,12,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="TextBoxColumn" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Capture Count Down Period (sec):" FontWeight="Bold" FontStyle="Italic" Foreground="Purple" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        <TextBox x:Name="tbTime" Grid.Column="1" Margin="12,0,0,0" Width="100" Text="{Binding WindGaugeCaptureCountdown, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseWallClockTimeOfDay}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                    <Grid Grid.Row="4" Grid.Column="0" Margin="0,12,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="LabelColumn" />
                            <ColumnDefinition Width="Auto" SharedSizeGroup="TextBoxColumn" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Captures per:" FontWeight="Bold" FontStyle="Italic" Foreground="Purple" VerticalAlignment="Center" HorizontalAlignment="Right" />
                        <TextBox x:Name="tbCountsPerSec" Grid.Column="1" Margin="12,0,0,0" Width="100" Text="{Binding SiriccoAcquisitionMeasurementsPerSec, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseWallClockTimeOfDay}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>


                    </Grid>

                </Grid>
            </GroupBox>

            <Border x:Name="rightSevenSegBorder" Grid.Column="1" Margin="12,0,0,0" BorderBrush="#FFCC0000" BorderThickness="3" CornerRadius="4" Background="Black" Padding="10" VerticalAlignment="Stretch" Visibility="Collapsed">
                <Viewbox x:Name="rightSevenSegViewbox" Stretch="Uniform" StretchDirection="Both" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid x:Name="rightSevenSegContent">
                        <controls:SixDigitSevenSegmentDisplay TimeInput="{Binding WindGaugeDisplay}" NumDigits="5" ShowDecimalDot="{Binding ShowDecimalDot}" />
                    </Grid>
                </Viewbox>
            </Border>
        </Grid>

        <Border x:Name="bottomSevenSegBorder" Grid.Row="5" Margin="0,12,0,0" BorderBrush="#FFCC0000" BorderThickness="3" CornerRadius="4" Background="Black" Padding="10" HorizontalAlignment="Left" Visibility="Visible">
            <Viewbox x:Name="bottomSevenSegViewbox" Stretch="None" StretchDirection="Both" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Grid x:Name="bottomSevenSegContent">
                    <controls:FourDigitSevenSegmentDisplay TimeInput="{Binding WindGaugeDisplay}" NumDigits="4"  ShowDecimalDot="{Binding ShowDecimalDot}" />
                </Grid>
            </Viewbox>
        </Border>
        <Border x:Name="status1Border" Grid.Row="6" Margin="0,12,0,0" Padding="10" Background="#FFEFEFEF" CornerRadius="4">
            <TextBlock Text="{Binding SendStatus}" TextWrapping="Wrap" />
        </Border>
        <Border x:Name="status2Border" Grid.Row="7" Margin="0,12,0,0" Padding="10" Background="#FFEFEFEF" CornerRadius="4">
            <TextBlock Text="{Binding RecvStatus}" TextWrapping="Wrap" />
        </Border>
        <Border x:Name="statusBorder" Grid.Row="8" Margin="0,12,0,0" Padding="10" Background="#FFEFEFEF" CornerRadius="4">
            <TextBlock Text="{Binding Status}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>

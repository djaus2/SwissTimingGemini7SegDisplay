<Window x:Class="SwissTimingDisplay.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Swiss Timing Display" 
        Height="300" 
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#2C3E50">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">


            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Image Source="pack://application:,,,/docs/SwissTiming.png" 
                       Height="40" Stretch="Uniform" 
                       VerticalAlignment="Center" Margin="0,10,0,10" 
                       Grid.Row="0" Grid.Column="1"/>


                <!-- Left image -->
                <Image Source="pack://application:,,,/docs/gemini6display.png"
           Height="100"
           Stretch="Uniform"
           VerticalAlignment="Center"
           HorizontalAlignment="Left"
           Grid.Column="0" Grid.Row="1"/>

                <!-- Right image -->
                <Image Source="pack://application:,,,/docs/mistralwindgauge.png"
           Height="120"
           Stretch="Uniform"
           VerticalAlignment="Bottom"
           HorizontalAlignment="Right"
                       Grid.Row="0"
                       Grid.RowSpan="2"
           Grid.Column="2"/>
            </Grid>


            <TextBlock Text="Select Mode:" 
                       FontSize="16" 
                       Foreground="#BDC3C7"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Name="DisplayButton"
                        Content="Display"
                        Width="120"
                        Height="45"
                        FontSize="16"
                        Margin="0,0,10,0"
                        Background="#3498DB"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="DisplayButton_Click"/>
                
                <Button Name="WindGaugeButton"
                        Content="Wind Gauge"
                        Width="120"
                        Height="45"
                        FontSize="16"
                        Margin="0,0,20,0"
                        Background="Green"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="WindGaugeButton_Click"/>
                <Button Name="ExitButton"
                        Content="Exit"
                        Width="60"
                        Height="30"
                        FontSize="16"
                        FontStyle="Italic"
                        Background="#E74C3C"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="ExitButton_Click"/>
            </StackPanel>

            <TextBlock Text="Disclaimer: This software is for demostration and testing purposes only and is not provided by Swiss Timing.&#x0A;Swiss Timing Display and Wind Gauge Transmission Protocols as referenced are used though."
           FontSize="12"
           FontStyle="Italic"
           Foreground="#BDC3C7"
           TextWrapping="Wrap"
                       TextAlignment="Justify"
           HorizontalAlignment="Center"
           Margin="0,10,0,20" Width="414" RenderTransformOrigin="0.5,0.5">
                <TextBlock.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleX="-1.315"/>
                        <RotateTransform/>
                        <TranslateTransform X="-0.977"/>
                    </TransformGroup>
                </TextBlock.RenderTransform>
            </TextBlock>

        </StackPanel>
        
    </Grid>
</Window>

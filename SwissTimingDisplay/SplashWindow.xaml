<Window x:Class="SwissTimingDisplay.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Swiss Timing Display" 
        Height="300" 
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#00A2E8">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">


            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Image Source="pack://application:,,,/docs/SwissTiming.png" 
                       Height="40" Stretch="Uniform" 
                       VerticalAlignment="Center" Margin="0,10,0,10" 
                       Grid.Row="0" Grid.Column="1"/>
                


                <!-- Left image -->
                <Image Source="pack://application:,,,/docs/gemini6display.png"
                       Height="100"
                       Stretch="Uniform"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Grid.Column="0" Grid.Row="1"/>

                <!-- Centre Image -->
                <Image Source="pack://application:,,,/docs/siriccoWindGauge2.png" 
                       Height="100" Stretch="Uniform" 
                       VerticalAlignment="Center" Margin="0" 
                       Grid.Row="1" Grid.Column="1"/>

                <!-- Right image -->
                <Image Source="pack://application:,,,/docs/mistralwindgauge.png"
                       Height="140"
                       Stretch="Uniform"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Right"
                        Grid.Row="0"
                        Grid.RowSpan="2"
                       Grid.Column="2"/>
            </Grid>


            <TextBlock Text="Select Mode:" 
                       FontSize="16" 
                       Foreground="#BDC3C7"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Name="DisplayButton"
                        Content="Display"

                        Width="100"
                        Height="45"
                        FontSize="16"
                        Margin="5,0,0,0"
                        Background="Red"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="DisplayButton_Click"/>
                
                <Button Name="SiriccoButton"
                        Content="Siricco Wind Gauge"

                        Width="140"
                        Height="45"
                        FontSize="16"
                        Margin="20,0,10,0"
                        Background="Green"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="SiriccoWindGaugeButton_Click"/>
                
                <Button Name="WindGaugeButton"
                        Content="Mistral Wind Gauge"
                        Width="145"
                        Height="45"
                        FontSize="16"
                        Margin="20,0,5,0"
                        Background="Purple"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="WindGaugeButton_Click"/>

            
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Button Name="ExitButton"
                    Content="Exit"
                    Width="100"
                    Height="45"
                    FontSize="16"
                    FontStyle="Italic"
                        Margin="5,0,5,0"
                    Background="brown"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="ExitButton_Click"/>
                <TextBlock Text="Disclaimer: This software is for demostration and testing&#x0A;purposes only and is not provided by Swiss Timing.&#x0A;Swiss Timing Display and Wind Gauge Transmission&#x0A;Protocols as referenced are used though."
               FontSize="12"
               FontStyle="Italic"
               Foreground="#BDC3C7"
               TextWrapping="Wrap"
                           TextAlignment="Justify"
               HorizontalAlignment="Center"
               Margin="20,10,5,20" Width="335"  RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform AngleX="-1.315"/>
                            <RotateTransform/>
                            <TranslateTransform X="-0.977"/>
                        </TransformGroup>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </StackPanel>

        </StackPanel>
        
    </Grid>
</Window>
